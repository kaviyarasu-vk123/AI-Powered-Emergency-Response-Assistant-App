from fastapi import FastAPI

app = FastAPI()

@app.get("/")
def home():
    return {"message": "ResQ API Running"}

@app.post("/emergency")
def detect_emergency(text: str):
    if "heart" in text.lower():
        return {
            "type": "Cardiac Emergency",
            "severity": "Critical",
            "confidence": "91%"
        }
    return {"type": "Unknown"}
